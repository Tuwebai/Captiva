{
  "name": "captiva-landing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "normalize:demos": "node scripts/normalize-demo-metadata.mjs",
    "validate:demos": "npm run normalize:demos && node scripts/validate-demos.mjs",
    "generate:city-landings": "node scripts/generate-city-landings.mjs",
    "generate:landing-examples": "node scripts/generate-landing-examples.mjs",
    "generate:blog": "node scripts/generate-blog-manifest.mjs",
    "generate:demos": "npm run normalize:demos && node scripts/generate-demos-manifest.mjs",
    "generate:seo-indexes": "node scripts/build/generate-seo-indexes.mjs",
    "generate:sitemaps": "node scripts/seo/generate-sitemaps.mjs",
    "obfuscate:demos": "node scripts/obfuscate-demo-scripts.mjs",
    "build:demos": "npm run generate:demos && npm run obfuscate:demos",
    "dev": "npm run validate:demos && npm run generate:city-landings && npm run generate:landing-examples && npm run generate:blog && npm run build:demos && npm run generate:seo-indexes && npm run generate:sitemaps && vite",
    "build": "npm run validate:demos && npm run generate:city-landings && npm run generate:landing-examples && npm run generate:blog && npm run build:demos && npm run generate:seo-indexes && npm run generate:sitemaps && tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "html-minifier-terser": "^7.2.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "typescript": "^5.9.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^7.1.3",
    "yaml": "^2.8.1"
  }
}
