{
  "name": "captiva-landing",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "check": "tsc -b",
    "lint": "node scripts/quality/lint-project.mjs && node scripts/quality/check-text-encoding.mjs",
    "smoke": "node scripts/quality/smoke-build.mjs",
    "test": "vitest run --environment jsdom",
    "generate:city-landings": "node scripts/generate-city-landings.mjs",
    "generate:landing-examples": "node scripts/generate-landing-examples.mjs",
    "generate:blog": "node scripts/generate-blog-manifest.mjs",
    "generate:seo-indexes": "node scripts/build/generate-seo-indexes.mjs",
    "generate:sitemaps": "node scripts/seo/generate-sitemaps.mjs",
    "sync:public-demos": "node scripts/build/sync-public-demos.mjs",
    "dev": "npm run generate:city-landings && npm run generate:landing-examples && npm run generate:blog && npm run generate:seo-indexes && npm run generate:sitemaps && npm run sync:public-demos && vite",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.tsx --outDir .prerender",
    "prerender:routes": "node scripts/build/prerender-static-routes.mjs",
    "build": "npm run generate:city-landings && npm run generate:landing-examples && npm run generate:blog && npm run generate:seo-indexes && npm run generate:sitemaps && npm run sync:public-demos && tsc -b && npm run build:client && npm run build:ssr && npm run prerender:routes",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^20.19.37",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "html-minifier-terser": "^7.2.0",
    "jsdom": "^26.1.0",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vite": "^7.1.3",
    "vitest": "^3.2.4",
    "yaml": "^2.8.1"
  }
}
